# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,fsproj,props,xml}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.cs]
# ── Imports ───────────────────────────────────────────────────────────────────
csharp_using_directive_placement = outside_namespace:warning
dotnet_separate_import_directive_groups = true
dotnet_sort_system_directives_first = true

# ── Namespace style ───────────────────────────────────────────────────────────
csharp_style_namespace_declarations = file_scoped:warning

# ── Access modifiers ──────────────────────────────────────────────────────────
dotnet_style_require_accessibility_modifiers = always:warning
# public > protected > internal > private > file, then static, then others
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:suggestion

# ── Naming: private fields use _camelCase ─────────────────────────────────────
dotnet_naming_rule.private_members_with_underscore.severity = warning
dotnet_naming_rule.private_members_with_underscore.style = prefix_underscore
dotnet_naming_rule.private_members_with_underscore.symbols = private_fields
dotnet_naming_style.prefix_underscore.capitalization = camel_case
dotnet_naming_style.prefix_underscore.required_prefix = _
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.applicable_kinds = field

# ── var: prefer var for all local variables ───────────────────────────────────
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# ── Expression bodies ─────────────────────────────────────────────────────────
# Single-expression members use => regardless of whether they span multiple lines
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_operators = true:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_indexers = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = true:suggestion

# ── Braces — always required (aligns with CSharpier enforcement) ──────────────
csharp_prefer_braces = true:warning

# ── Null handling ─────────────────────────────────────────────────────────────
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning
csharp_style_prefer_null_check_over_type_check = true:suggestion
csharp_style_throw_expression = true:suggestion

# ── Pattern matching ──────────────────────────────────────────────────────────
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_extended_property_pattern = true:suggestion

# ── Object and collection initializers ───────────────────────────────────────
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion

# ── Target-typed new() ────────────────────────────────────────────────────────
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# ── Readonly fields ───────────────────────────────────────────────────────────
dotnet_style_readonly_field = true:warning

# ── Primary constructors (preferred for DI over traditional constructors) ─────
csharp_style_prefer_primary_constructors = true:suggestion

# ── Local functions ───────────────────────────────────────────────────────────
csharp_style_prefer_local_over_anonymous_function = true:suggestion
csharp_prefer_static_local_function = true:suggestion

# ── String and interpolation ──────────────────────────────────────────────────
dotnet_style_prefer_simplified_interpolation = true:suggestion

# ── Miscellaneous ─────────────────────────────────────────────────────────────
csharp_prefer_simple_default_expression = true:suggestion
dotnet_style_prefer_compound_assignment = true:suggestion

# ── Analyzer severities ───────────────────────────────────────────────────────
# Use nameof() instead of a string literal for method/property/parameter names
dotnet_diagnostic.CA1507.severity = warning
# Specify a culture-aware comparison explicitly where string ordering matters
dotnet_diagnostic.CA1310.severity = warning
# Use ordinal StringComparison in string operations that are culture-invariant
dotnet_diagnostic.CA1309.severity = warning
# Use InvariantCulture / IFormatProvider where a format provider is accepted
dotnet_diagnostic.CA1305.severity = warning
